              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Integration"},
            "properties": [{"id": "custom.width", "value": 120}]
          },
          {
            "matcher": {"id": "byName", "options": "Operation"},
            "properties": [{"id": "custom.width", "value": 150}]
