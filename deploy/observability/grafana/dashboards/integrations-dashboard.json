      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(integration_requests_total{status!=\"success\"}[1h])) by (integration, operation) / sum(rate(integration_requests_total[1h])) by (integration, operation)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Error Rate by Integration & Operation",
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true}, "renameByName": {"integration": "Integration", "operation": "Operation", "Value": "Error Rate"}}}
      ],
      "type": "table"
